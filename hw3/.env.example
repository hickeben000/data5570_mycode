# Copy this file to `.env` on your laptop and set your EC2 API URL.
# Expo injects only variables that start with EXPO_PUBLIC_.
#
# Example (replace with your EC2 public IP or cloudflared URL):
# EXPO_PUBLIC_API_BASE_URL=http://12.34.56.78:8000/api
#
# If you use a Cloudflare tunnel (HTTPS):
# EXPO_PUBLIC_API_BASE_URL=https://your-subdomain.trycloudflare.com/api
#
EXPO_PUBLIC_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8000/api
