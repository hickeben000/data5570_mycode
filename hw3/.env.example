# Copy this file to `.env` and set EXPO_PUBLIC_API_BASE_URL.
# Expo injects only variables that start with EXPO_PUBLIC_.
# Restart Expo (npm start) after changing this file.
#
# --- Option A: HTTP to EC2 public IP (security group must allow TCP 8000) ---
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8000/api
#
# --- Option B: HTTPS via Cloudflare quick tunnel (run on EC2; see myproject/scripts/start-cloudflared-tunnel.sh) ---
# cloudflared prints a URL like https://xxxxx.trycloudflare.com — use it below:
# EXPO_PUBLIC_API_BASE_URL=https://xxxxx.trycloudflare.com/api
#
# Note: 127.0.0.1 / your laptop LAN (e.g. 144.x.x.x) is for Expo only, not the Django API URL.
#
EXPO_PUBLIC_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8000/api
